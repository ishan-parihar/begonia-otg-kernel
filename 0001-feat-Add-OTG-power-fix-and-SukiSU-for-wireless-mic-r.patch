+#!/bin/bash
+
+set -e
+
+OUT_DIR="out"
+DEFCONFIG="${2:-begonia_user_defconfig}"
+
+GREEN='\033[0;32m'
+NC='\033[0m'
+
+msg() { echo -e "${GREEN}[+] $1${NC}"; }
+err() { echo -e "\033[0;31m[!] $1\033[0m"; exit 1; }
+
+build_kernel() {
+    msg "Building kernel with system toolchain..."
+    
+    export ARCH=arm64
+    export SUBARCH=arm64
+    export KBUILD_BUILD_USER="opencode"
+    export KBUILD_BUILD_HOST="archlinux"
+    
+    mkdir -p "$OUT_DIR"
+    
+    msg "Generating config..."
+    make O="$OUT_DIR" ARCH=arm64 "$DEFCONFIG"
+    
+    msg "Compiling..."
+    make -j"$(nproc)" O="$OUT_DIR" ARCH=arm64 \
+        CC="clang" \
+        LD="ld.lld" \
+        CROSS_COMPILE="aarch64-linux-gnu-" \
+        CROSS_COMPILE_ARM32="arm-linux-gnueabi-" \
+        CLANG_TRIPLE="aarch64-linux-gnu-" \
+        2>&1 | tee build_log.txt
+    
+    if [ -f "$OUT_DIR/arch/arm64/boot/Image.gz-dtb" ]; then
+        msg "Build successful!"
+        msg "Kernel image: $OUT_DIR/arch/arm64/boot/Image.gz-dtb"
+    else
+        err "Build failed!"
+    fi
+}
+
+case "$1" in
+    -b|--build)
+        build_kernel
+        ;;
+    *)
+        echo "Usage: $0 [option] [defconfig]"
+        echo "  -b, --build    Build kernel"
+        exit 1
+        ;;
+esac
